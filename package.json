{
  "name": "setup-react",
  "version": "0.0.0-development",
  "description": "GitHub Action to set up your workflow with a specific version of React",
  "author": "Kirk Eaton <contact@kirkeaton.ca>",
  "bugs": {
    "url": "https://github.com/kirkeaton/setup-react/issues"
  },
  "dependencies": {
    "@actions/core": "1.11.1",
    "package-manager-detector": "^1.0.0"
  },
  "devDependencies": {
    "@kirkeaton/prettier-config": "1.0.5",
    "@kirkeaton/semantic-release-config": "1.0.4",
    "@kirkeaton/tsconfig": "1.0.3",
    "@types/node": "22.16.5",
    "esbuild": "0.25.7",
    "prettier": "3.6.2",
    "semantic-release": "24.2.7",
    "typescript": "5.8.3"
  },
  "exports": "./dist/index.js",
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/kirkeaton/setup-react#readme",
  "keywords": [
    "actions",
    "react",
    "setup"
  ],
  "license": "BSD-3-Clause",
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
